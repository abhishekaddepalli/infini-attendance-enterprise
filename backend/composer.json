{
    "name": "infini/attendance",
    "description": "Infini Attendance - Enterprise Workforce Management Platform",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "laravel/sanctum": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Infini\\Attendance\\": "src/"
        },
        "files": [
